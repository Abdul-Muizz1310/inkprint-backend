# ─── Core ──────────────────────────────────────────
APP_ENV=development                    # development | staging | production
LOG_LEVEL=debug                        # debug | info | warn | error
PORT=8000

# ─── Database (Neon, branch: inkprint) ────────────
DATABASE_URL=postgresql+asyncpg://user:pw@ep-xyz.neon.tech/inkprint?sslmode=require

# ─── Signing keys (Ed25519, base64-encoded PEM) ──
# Generate via: uv run python scripts/generate_keys.py
INKPRINT_SIGNING_KEY_PRIVATE=
INKPRINT_SIGNING_KEY_PUBLIC=
INKPRINT_KEY_ID=inkprint-ed25519-2026-04

# ─── Embeddings (Voyage AI) ──────────────────────
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-lite

# ─── LLM (OpenRouter, optional for leak explanations) ──
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=              # picked at integration time

# ─── Cloudflare R2 (S3-compatible blob storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=muizz-lab
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE=                        # optional, leave blank for signed URLs

# ─── Leak corpora endpoints ─────────────────────
COMMON_CRAWL_CDX=https://index.commoncrawl.org/CC-MAIN-2024-50-index
HF_DATASETS_API=https://datasets-server.huggingface.co
BIGCODE_STACK_API=https://huggingface.co/api/datasets/bigcode/the-stack-v2

# ─── Thresholds ─────────────────────────────────
LEAK_CONFIDENCE_THRESHOLD=0.7
DERIVATIVE_HAMMING_THRESHOLD=12
DERIVATIVE_COSINE_THRESHOLD=0.85
MAX_TEXT_BYTES=500000                   # 500 KB cap per submission

# ─── Observability ───────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ─── Platform (bastion integration) ─────────────
BASTION_PUBLIC_KEY_URL=https://bastion.vercel.app/api/public-key
DEMO_MODE=true
